# ============================================================================
# AGENTE DE SOPORTE — FULLMINDTECH
# Copiar este archivo como .env y completar los valores
# NUNCA commitear el archivo .env
# ============================================================================

# ----------------------------------------------------------------------------
# WhatsApp / Meta (Cloud API)
# ----------------------------------------------------------------------------
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=mi_token_secreto_webhook
META_API_URL=https://graph.facebook.com/v19.0

# ----------------------------------------------------------------------------
# Plane (Gestión de tickets)
# ----------------------------------------------------------------------------
PLANE_API_URL=https://api.plane.so/api/v1
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=
PLANE_PROJECT_ID=
# Proyecto de Plane donde se almacenan las FAQs
PLANE_FAQ_PROJECT_ID=

# ----------------------------------------------------------------------------
# LLM — OpenAI (o compatible)
# ----------------------------------------------------------------------------
OPENAI_API_KEY=
# Modelo a usar por defecto. Ejemplos: gpt-4o, gpt-4o-mini
LLM_MODEL=gpt-4o

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# ----------------------------------------------------------------------------
# Admin UI
# ----------------------------------------------------------------------------
# Clave para el panel de administración (se usa como contraseña del login)
ADMIN_API_KEY=cambia-esta-clave
# Orígenes permitidos para CORS (incluir la URL del admin-ui)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
# Orígenes permitidos para iframes (CSP frame-ancestors). Usar '*' solo en desarrollo
ALLOWED_FRAME_ANCESTORS=*
# Puerto expuesto del admin-ui en docker-compose (default: 8080)
ADMIN_UI_PORT=8080
