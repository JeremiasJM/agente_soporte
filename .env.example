# ============================================================================
# AGENTE DE SOPORTE — FULLMINDTECH
# Copiar este archivo como .env y completar los valores
# NUNCA commitear el archivo .env
# ============================================================================

# ----------------------------------------------------------------------------
# Base de datos (PostgreSQL)
# ----------------------------------------------------------------------------


# ----------------------------------------------------------------------------
# WhatsApp / Meta (Cloud API)
# ----------------------------------------------------------------------------
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=mi_token_secreto_webhook
META_API_URL=https://graph.facebook.com/v19.0

# ----------------------------------------------------------------------------
# Plane (Gestión de tickets)
# ----------------------------------------------------------------------------
PLANE_API_URL=https://api.plane.so/api/v1
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=
PLANE_PROJECT_ID=

# ----------------------------------------------------------------------------
# Uptime / Monitoreo
# ----------------------------------------------------------------------------
UPTIME_API_URL=
UPTIME_API_KEY=

# ----------------------------------------------------------------------------
# LLM — OpenRouter (gateway de modelos)
# ----------------------------------------------------------------------------
LLM_API_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
# Modelo a usar por defecto. Ejemplos:
#   anthropic/claude-3-5-sonnet
#   openai/gpt-4o
#   google/gemini-2.0-flash
LLM_MODEL=anthropic/claude-3-5-sonnet

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
